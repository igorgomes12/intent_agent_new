# ============================================
# CONFIGURAÇÕES GCP - VERTEX AI
# ============================================

# Projeto GCP (Vertex AI)
GCP_PROJECT_ID=seu-projeto-gcp
GCP_LOCATION=us-central1

# Credenciais Vertex AI (caminho para key.json)
GOOGLE_APPLICATION_CREDENTIALS=./key.json

# ============================================
# CONFIGURAÇÕES FIRESTORE (se em projeto diferente)
# ============================================

# Projeto Firestore (deixe vazio para usar o mesmo do Vertex AI)
FIRESTORE_PROJECT_ID=

# Credenciais Firestore (deixe vazio para usar as mesmas do Vertex AI)
FIRESTORE_CREDENTIALS=

# ============================================
# CONFIGURAÇÕES LOCAIS
# ============================================

# Caminho para flows locais (JSON)
FLOWS_PATH=./flows

# Threshold para usar Gemini (0.0 - 1.0)
GEMINI_THRESHOLD=0.5

# ============================================
# FIRESTORE
# ============================================

# Habilitar Firestore (true/false)
USE_FIRESTORE=false

# Nome do database Firestore
FIRESTORE_DATABASE=(default)

# ============================================
# VECTOR SEARCH
# ============================================

# Habilitar Vector Search (true/false)
USE_VECTOR_SEARCH=false

# Endpoint do índice vetorial
VECTOR_SEARCH_INDEX_ENDPOINT=projects/123456789/locations/us-central1/indexEndpoints/abc123

# Índices deployados
VECTOR_SEARCH_DEPLOYED_INDEX_FLOWS=flows_index
VECTOR_SEARCH_DEPLOYED_INDEX_TABLES=tables_index

# ============================================
# DOCUMENT AI
# ============================================

# ID do processador Document AI
DOCUMENT_AI_PROCESSOR_ID=abc123def456

# ============================================
# CLOUD SPANNER (GRAFO)
# ============================================

# Habilitar Spanner (true/false)
USE_SPANNER=false

# Instância e database Spanner
SPANNER_INSTANCE=metadata-graph
SPANNER_DATABASE=relationships
